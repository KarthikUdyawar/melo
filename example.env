# ── Copy to .env.development / .env.staging / .env.production ─────────────────
# APP_ENV drives which file is loaded at startup. Valid values:
#   development  →  .env.development  (local machine, localhost endpoints)
#   staging      →  .env.staging      (Docker Compose, service-name hostnames)
#   production   →  .env.production   (real infra, all secrets required)

APP_ENV=development
LOG_LEVEL=debug

# PostgreSQL
DATABASE_URL=postgresql://melo:melo@localhost:5432/melo

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER=redis://localhost:6379/0
CELERY_BACKEND=redis://localhost:6379/1

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=songs
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:9000
