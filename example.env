# ── Copy to .env.development / .env.staging / .env.production ─────────────────
# APP_ENV drives which file is loaded at startup. Valid values:
#   development  →  .env.development  (local machine, localhost endpoints)
#   staging      →  .env.staging      (Docker Compose, service-name hostnames)
#   production   →  .env.production   (real infra, all secrets required)

APP_ENV=development
LOG_LEVEL=debug
LOG_FILE_PATH=/var/log/melo/app.log

# PostgreSQL
DATABASE_URL=postgresql://melo:melo@localhost:5432/melo

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER=redis://localhost:6379/0
CELERY_BACKEND=redis://localhost:6379/1

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=songs
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:9000

# ── Observability (OBS-0) ──────────────────────────────────────────────────────

# Grafana
GRAFANA_ADMIN_PASSWORD=admin

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Streamlit admin
ADMIN_PASSWORD=

# Log rotation
LOG_MAX_SIZE_MB=10
LOG_MAX_AGE_HOURS=24
LOG_BACKUP_BUCKET=melo-log-backups
LOG_RETENTION_DAYS=90

# Pyroscope
PYROSCOPE_SERVER_URL=http://pyroscope:4040

# MinIO metrics scrape (Prometheus bearer token auth)
# Generate: mc admin prometheus generate <alias>
MINIO_METRICS_TOKEN=

# Celery event stream (required for celery-exporter to emit metrics)
CELERY_SEND_EVENTS=True
CELERY_TASK_TRACK_STARTED=True
